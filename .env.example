# =============================================================================
# Knowledge OS Core — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=change_me_in_production

# Connection string for the application
# DATABASE_URL is built automatically by docker-compose from the above
# For local development without Docker:
# DATABASE_URL=postgresql+asyncpg://postgres:{POSTGRES_PASSWORD}@localhost:5432/knowledge_os

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Set to "json" for production JSON logs, "console" for human-readable
LOG_FORMAT=console

# Enable SQL query logging (very verbose, use for debugging only)
SQL_ECHO=false

# -----------------------------------------------------------------------------
# Worker
# -----------------------------------------------------------------------------
# Unique ID for this worker instance (auto-generated if not set)
WORKER_ID=worker-1

# -----------------------------------------------------------------------------
# Authentication (v1: no auth, future versions)
# -----------------------------------------------------------------------------
# X-Actor header passed by frontend (for v1, always "user")
# ACTOR_HEADER=X-Actor

# -----------------------------------------------------------------------------
# OpenTelemetry (optional)
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=knowledge-os

# -----------------------------------------------------------------------------
# Caddy / HTTPS (production)
# -----------------------------------------------------------------------------
# Cloudflare API token for automatic DNS challenge
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Email for Let's Encrypt certificate notifications
# ACME_EMAIL=your@email.com

# -----------------------------------------------------------------------------
# Frontend (for production builds)
# -----------------------------------------------------------------------------
# VITE_API_URL=https://your-domain.com/api
